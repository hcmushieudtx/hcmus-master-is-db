# This directory is populated by running: make sqlc-generate
# which executes: cd db/postgres && sqlc generate
#
# sqlc reads sqlc.yaml + queries/*.sql + migrations/*.up.sql and produces:
#   db.go       — DBTX interface and Queries constructor
#   querier.go  — Querier interface (all named queries)
#   models.go   — Go structs mirroring PostgreSQL tables
#   *.sql.go    — Typed implementations of each named query
#
# Do NOT commit generated files; add store/*.go to .gitignore if preferred.
