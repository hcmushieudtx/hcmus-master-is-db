# Application
ENV=development
LOGGER_LEVEL=info

# HTTP Server
SERVER_PORT=8080

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bookstore
POSTGRES_USER=developer
POSTGRES_PASSWORD=devpassword
POSTGRES_SSLMODE=disable

# MongoDB
MONGO_URI=mongodb://developer:devpassword@localhost:27017/bookstore?authSource=admin
MONGO_DB=bookstore
MONGO_USER=developer
MONGO_PASSWORD=devpassword

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=devpassword

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=admin
REDIS_DB=0

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_TTL=168h

# ── Feature flags (Redis caching) ─────────────────────────────────────────────
# Set any flag to false to disable the corresponding Redis caching feature.
FEATURES_REDIS_BOOK_CACHE=true
FEATURES_REDIS_NEWEST_BOOKS=true
FEATURES_REDIS_STOCK_CACHE=true
FEATURES_REDIS_CART_CACHE=true
FEATURES_REDIS_BEST_SELLERS=true
FEATURES_REDIS_ORDER_HISTORY=true
FEATURES_REDIS_MOST_VIEWED_DAILY=true
FEATURES_REDIS_MOST_VIEWED_30D=true
FEATURES_REDIS_CATEGORY_CACHE=true
